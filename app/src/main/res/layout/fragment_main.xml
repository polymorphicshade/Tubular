<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">


    <org.schabi.newpipe.views.ScrollableTabLayout
        android:id="@+id/main_tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="?android:attr/windowBackground"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:tabBackground="@drawable/yt_tab_chip_bg"
        app:tabRippleColor="?attr/contrast_background_color"
        app:tabIconTint="@drawable/yt_tab_chip_icon_color"
        app:tabIndicatorHeight="0dp"
        app:tabPaddingStart="14dp"
        app:tabPaddingEnd="14dp"
        app:tabMinWidth="0dp"
        app:tabTextAppearance="@style/YTChipTabText"
        app:tabTextColor="?android:attr/textColorPrimary"
        app:tabSelectedTextColor="?android:attr/textColorPrimaryInverse" />

    <androidx.viewpager.widget.ViewPager
        android:id="@+id/pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/main_tab_layout" />

</RelativeLayout>
